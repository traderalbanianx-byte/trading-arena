# ─── TELEGRAM ────────────────────────────────────────────────
# Get these from https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# Your 4 channel @usernames (without the @) or numeric IDs
CHANNEL_CASH=your_cash_channel_username
CHANNEL_GAULS=your_gauls_channel_username
CHANNEL_TITAN=your_titan_channel_username
CHANNEL_BAMP=your_bamp_channel_username

# ─── ANTHROPIC ───────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── SERVER ──────────────────────────────────────────────────
PORT=5000
DELAY_HOURS=48
ADMIN_SECRET=change_this_to_something_strong
FLASK_DEBUG=false
